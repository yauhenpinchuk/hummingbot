# SOL-PUMP Bot — Secrets
# Copy to /opt/sol-pump-bot/.secrets/env on the server.
# chmod 600 /opt/sol-pump-bot/.secrets/env
# NEVER commit this file to git.

# Gateway passphrase — encrypts the Solana wallet stored in gateway-conf/wallets/
# Can be any strong passphrase — independent of local setup.
GATEWAY_PASSPHRASE=change_me_strong_passphrase

# Hummingbot config password — decrypts connector credentials in conf/connectors/
# Must match the password used when hummingbot was first configured locally.
CONFIG_PASSWORD=change_me_hummingbot_password
